# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cybersecurity News API keys (stored in environment variables)
# NewsAPI (Primary source)
NEWS_API_KEY=""
VITE_NEWS_API_KEY=""

# GNews API (Secondary failover source)
GNEWS_API_KEY=""
VITE_GNEWS_API_KEY=""

# --- THREAT INTELLIGENCE APIS ---
# VirusTotal API Key (IP/Domain/Hash reputations)
VIRUSTOTAL_API_KEY=""

# AbuseIPDB API Key (IP security reputations)
ABUSEIPDB_API_KEY=""

# AlienVault OTX API Key (IP/Hash IOC checking)
ALIENVAULT_OTX_API_KEY=""

# URLScan.io API Key (URL analysis scans)
URLSCAN_API_KEY=""

# Google Safe Browsing API Key (Web target checks)
GOOGLE_SAFE_BROWSING_API_KEY=""

# --- VULNERABILITY INTELLIGENCE APIS ---
# NIST National Vulnerability Database API Key (CVE Details queries)
NIST_NVD_API_KEY=""

# --- IDENTITY & BREACH APIS ---
# Have I Been Pwned API Key (Email breach audits)
HIBP_API_KEY=""

# --- DNS & DOMAIN INTELLIGENCE APIS ---
# SecurityTrails API Key (DNS history queries)
SECURITYTRAILS_API_KEY=""

# WhoisXML API Key (WHOIS owner registries)
WHOISXML_API_KEY=""

